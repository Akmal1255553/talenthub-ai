generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum VacancyStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  PAUSED
  CLOSED
  REJECTED
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  BUSINESS
}

enum SubscriptionOwnerType {
  CANDIDATE
  COMPANY
}

enum AiCapability {
  RESUME_IMPROVE
  JOB_RECOMMENDATIONS
  CANDIDATE_SCORING
  COVER_LETTER
  ASSISTANT_CHAT
  EMPLOYER_ANALYTICS
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String
  name            String
  role            UserRole
  status          UserStatus        @default(ACTIVE)
  refreshHash     String?
  candidate       CandidateProfile?
  companyMembers  CompanyMember[]
  applications    Application[]
  notifications   Notification[]
  aiRequests      AiRequest[]
  auditLogs        AuditLog[]        @relation("AuditActor")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model CandidateProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  headline    String?
  location    String?
  about       String?
  visibility  String   @default("PUBLIC")
  resumes     Resume[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Resume {
  id          String           @id @default(cuid())
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id])
  title       String
  content     Json
  aiScore     Int?
  promoted    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Company {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  description   String?
  website       String?
  verified      Boolean         @default(false)
  members       CompanyMember[]
  vacancies     Vacancy[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model CompanyMember {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      String   @default("OWNER")
  company   Company  @relation(fields: [companyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([companyId, userId])
}

model Vacancy {
  id             String           @id @default(cuid())
  companyId      String
  company        Company          @relation(fields: [companyId], references: [id])
  title          String
  slug           String           @unique
  description    String
  requirements   String?
  location       String?
  employmentType String
  salaryMin      Int?
  salaryMax      Int?
  currency       String           @default("USD")
  status         VacancyStatus    @default(DRAFT)
  promoted       Boolean          @default(false)
  applications   Application[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([location])
  @@index([employmentType])
}

model Application {
  id             String            @id @default(cuid())
  vacancyId      String
  candidateUserId String
  coverLetter    String?
  status         ApplicationStatus @default(APPLIED)
  aiScore        Int?
  aiSummary      String?
  vacancy        Vacancy           @relation(fields: [vacancyId], references: [id])
  candidate      User              @relation(fields: [candidateUserId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([vacancyId, candidateUserId])
  @@index([candidateUserId, createdAt])
}

model Chat {
  id          String        @id @default(cuid())
  vacancyId   String?
  messages    ChatMessage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  body      String
  readAt    DateTime?
  chat      Chat     @relation(fields: [chatId], references: [id])
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

model Subscription {
  id                 String                @id @default(cuid())
  ownerType          SubscriptionOwnerType
  ownerId            String
  plan               SubscriptionPlan      @default(FREE)
  provider           String?
  providerCustomerId String?
  providerSubId      String?
  status             String                @default("ACTIVE")
  currentPeriodEnd   DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([ownerType, ownerId])
}

model Payment {
  id            String   @id @default(cuid())
  ownerType     String
  ownerId       String
  provider      String
  providerRef   String   @unique
  amount        Int
  currency      String
  status        String
  createdAt     DateTime @default(now())
}

model AiRequest {
  id          String       @id @default(cuid())
  userId      String
  capability  AiCapability
  model       String
  inputTokens Int          @default(0)
  outputTokens Int         @default(0)
  costCents   Int          @default(0)
  status      String
  user        User         @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([capability, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entity, entityId])
}
