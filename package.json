{
  "name": "talenthub-ai",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx --yes concurrently -k -n api,web -c blue,magenta \"npm run dev -w @talenthub/api\" \"npm run dev -w @talenthub/web\"",
    "dev:api": "npm run dev -w @talenthub/api",
    "dev:web": "npm run dev -w @talenthub/web",
    "deploy:up": "docker compose up -d --build",
    "deploy:ps": "docker compose ps",
    "deploy:logs": "docker compose logs -f --tail=200",
    "deploy:down": "docker compose down",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run prisma:migrate -w apps/api",
    "db:generate": "npm run prisma:generate -w apps/api"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "devDependencies": {
    "fast-check": "^4.8.0",
    "pure-rand": "^8.4.0"
  }
}
