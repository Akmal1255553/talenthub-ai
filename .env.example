NODE_ENV=development

DATABASE_URL=postgresql://talenthub:talenthub@localhost:5432/talenthub
REDIS_URL=redis://localhost:6379
DISABLE_REDIS=true
SKIP_DB_CONNECT=true

JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Google OAuth (один и тот же Client ID в обе переменные)
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID (Web)
# Authorized JavaScript origins: http://localhost:3000
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Пока Client ID пустой — кнопка Google работает в режиме разработки (локально)
GOOGLE_DEV_MOCK=true
NEXT_PUBLIC_GOOGLE_DEV_MOCK=true
WEB_ORIGIN=http://localhost:3000

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

NEXT_PUBLIC_API_URL=http://localhost:4000
API_PORT=4000
WEB_PORT=3000
